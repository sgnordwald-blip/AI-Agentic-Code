# ============================================================
# SECTION 5: Flatten JSON
# ============================================================
def flatten_json(data, prefix=""):
    chunks = []

    if isinstance(data, dict):
        for k, v in data.items():
            new_prefix = f"{prefix}.{k}" if prefix else k
            chunks.extend(flatten_json(v, new_prefix))

    elif isinstance(data, list):
        for i, item in enumerate(data):
            new_prefix = f"{prefix}[{i}]"
            chunks.extend(flatten_json(item, new_prefix))

    else:
        chunks.append(f"{prefix}: {data}")

    return chunks


# ============================================================
# SECTION 6: Retrieval (RAG-style)
# ============================================================
def expand_query_with_synonyms(question):
    synonym_map = {
        "cheap": ["off_peak", "low", "discount", "cheaper"],
        "expensive": ["peak", "high", "costly"],
        "price": ["rate", "cost", "pricing"],
        "cost": ["price", "rate"],
        "save": ["savings", "discount", "off_peak"],
        "dryer": ["clothes dryer"],
        "washer": ["washing machine"],
        "electricity": ["kWh", "energy"],
        "peak": ["on_peak", "high demand"],
        "offpeak": ["off_peak", "low demand"],
        "hours": ["time", "period"]
    }

    words = question.lower().split()
    expanded_words = set(words)

    for word in words:
        if word in synonym_map:
            expanded_words.update(synonym_map[word])

    return list(expanded_words)


def retrieve_context(question, docs, k=8):
    expanded_words = expand_query_with_synonyms(question)
    scored = []

    for doc in docs:
        score = sum(word in doc.lower() for word in expanded_words)
        if score > 0:
            scored.append((score, doc))

    scored.sort(reverse=True)
    return "\n".join(d for _, d in scored[:k])


# ============================================================
# SECTION 7: Ask Energy Question
# ============================================================
def ask_energy_question(question, model, tokenizer, energy_data,
                        timezone_str="America/Denver", max_tokens=200):

    from datetime import datetime
    import pytz

    timezone = pytz.timezone(timezone_str)
    now = datetime.now(timezone)

    current_month = now.strftime("%B")
    current_time_str = now.strftime("%I:%M %p")

    def convert_to_24h(time_str):
        return datetime.strptime(time_str, "%I %p").hour

    def is_peak_hour(current_time, month, schedule):
        peak_start = schedule[month]["start"]
        peak_end = schedule[month]["end"]

        start_hour = convert_to_24h(peak_start)
        end_hour = convert_to_24h(peak_end)

        return start_hour <= current_time.hour < end_hour

    peak_status = is_peak_hour(now, current_month,
                              energy_data["monthly_peak_hours_schedule"])

    peak_note = (
        "It is currently PEAK hours."
        if peak_status else
        "It is currently OFF-PEAK hours."
    )

    docs = flatten_json(energy_data)
    context = retrieve_context(question, docs)

    enhanced_input = f"""
Current date and time: {now.isoformat()} ({current_time_str})
Location: {energy_data['location']['city']}, {energy_data['location']['state']}
Month: {current_month}
{peak_note}

Relevant appliance & rate info:
{context}
"""

    alpaca_prompt = """Below is an instruction that describes a task, paired with an input that provides further context.

### Instruction:
{}

### Input:
{}

### Response:
{}"""

    prompt = alpaca_prompt.format(question, enhanced_input, "")

    inputs = tokenizer(prompt, return_tensors="pt").to("cuda")

    outputs = model.generate(
        **inputs,
        max_new_tokens=max_tokens,
        use_cache=False,
        pad_token_id=tokenizer.eos_token_id
    )

    return tokenizer.decode(outputs[0], skip_special_tokens=True)


